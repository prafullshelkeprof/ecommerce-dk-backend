# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION environment variables for ecommerce-dk-backend
# Copy the values into Render → Environment when setting up your service.
# Never commit real secrets to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Get this from Neon dashboard → Connection string (postgresql://...)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Secrets (use strong random strings in production) ────────────────────────
JWT_SECRET=change-me-to-a-strong-random-string-32chars
COOKIE_SECRET=change-me-to-another-strong-random-string

# ── CORS (your Vercel frontend URL, no trailing slash) ───────────────────────
STORE_CORS=https://ecommerce-dk-dmrb.vercel.app
ADMIN_CORS=https://ecommerce-dk-dmrb.vercel.app
AUTH_CORS=https://ecommerce-dk-dmrb.vercel.app

# ── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=production

# ── Redis (optional – leave blank on free tier) ───────────────────────────────
# REDIS_URL=redis://...
